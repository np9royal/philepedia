---
type Props = {
  eyebrow: string;
  title: string;
  description?: string;
};

const { eyebrow, title, description } = Astro.props as Props;
---

<header class="space-y-3">
  <p class="text-[0.7rem] uppercase tracking-[0.4em] text-white/40">{eyebrow}</p>
  <div class="space-y-2">
    <h2 class="text-2xl font-medium tracking-[-0.03em] text-white sm:text-3xl">{title}</h2>
    {
      description && (
        <p class="max-w-3xl text-sm leading-7 text-white/58 sm:text-base">{description}</p>
      )
    }
  </div>
</header>
