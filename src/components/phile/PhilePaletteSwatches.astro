---
type Props = {
  palette: readonly string[];
  heroStyle: string;
  category: string;
};

const { palette, heroStyle, category } = Astro.props as Props;
---

<div class="grid gap-3 sm:grid-cols-5">
  {palette.map((color, index) => (
    <figure
      class="group overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-3 text-white/72 transition hover:-translate-y-0.5 hover:border-white/20"
      style={`background: linear-gradient(180deg, color-mix(in oklab, ${color} 28%, transparent), rgba(255,255,255,0.04));`}
    >
      <div class="flex items-center justify-between gap-3">
        <span class="text-[0.65rem] uppercase tracking-[0.35em] text-white/36">0{index + 1}</span>
        <span
          class="inline-flex h-8 w-8 rounded-full border border-white/20 shadow-[0_10px_30px_rgba(0,0,0,0.25)]"
          style={`background:${color}`}
          aria-hidden="true"
        />
      </div>
      <figcaption class="mt-10 space-y-1">
        <p class="text-sm font-medium text-white/82">{color}</p>
        <p class="text-xs uppercase tracking-[0.3em] text-white/36">{heroStyle}</p>
      </figcaption>
    </figure>
  ))}
</div>

<p class="mt-4 text-xs uppercase tracking-[0.35em] text-white/36">
  Signature mood for {category}
</p>
