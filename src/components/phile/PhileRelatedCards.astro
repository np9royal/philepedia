---
import type { CollectionEntry } from 'astro:content';

import { getPhilePath } from '../../lib/philes/content';

type Props = {
  philes: CollectionEntry<'philes'>[];
};

const { philes } = Astro.props as Props;
---

<div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
  {philes.map((entry) => (
    <a
      href={getPhilePath(entry.id)}
      class="group flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4 transition duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.07]"
    >
      <div class="flex items-center justify-between gap-4">
        <div class="space-y-1">
          <p class="text-[0.65rem] uppercase tracking-[0.35em] text-white/36">{entry.data.category}</p>
          <h3 class="text-[1.05rem] font-medium tracking-[-0.02em] text-white">{entry.data.name}</h3>
        </div>
        <span class="text-lg text-white/32 transition group-hover:translate-x-1 group-hover:text-white/70">
          →
        </span>
      </div>

      <p class="mt-3.5 text-sm leading-7 text-white/64">{entry.data.shortDescription}</p>

      <div class="mt-5 flex flex-wrap gap-1.5">
        {entry.data.tags.slice(0, 3).map((tag) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-[0.68rem] uppercase tracking-[0.25em] text-white/42">
            {tag}
          </span>
        ))}
      </div>
    </a>
  ))}
</div>
