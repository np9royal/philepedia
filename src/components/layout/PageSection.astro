---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  id?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  eyebrow,
  title,
  lead,
  id,
  align = 'left',
  class: className = ''
} = Astro.props as Props;
---

<section
  id={id}
  class={`mx-auto w-full max-w-7xl px-6 py-12 sm:px-8 lg:px-10 lg:py-16 ${className}`}
>
  <div class={align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}>
    {eyebrow && <p class="phile-eyebrow mb-3">{eyebrow}</p>}
    <h2 class="phile-display text-3xl tracking-tight text-[var(--phile-ink)] sm:text-4xl lg:text-5xl">{title}</h2>
    {lead && <p class="phile-prose mt-4 text-base sm:text-lg">{lead}</p>}
  </div>

  <div class="mt-10">
    <slot />
  </div>
</section>
