---
const brand = 'Philepedia';
---

<header class="relative z-10">
  <div class="mx-auto w-full max-w-7xl px-6 pt-4 sm:px-8 sm:pt-5 lg:px-10 lg:pt-6">
    <div class="flex flex-col gap-3 rounded-full border border-white/8 bg-white/[0.025] px-4 py-3 shadow-[0_14px_40px_rgba(0,0,0,0.14)] backdrop-blur-2xl sm:px-5 sm:py-3.5 md:flex-row md:items-center md:justify-between md:gap-4">
      <a
        href="/"
        class="group inline-flex items-center gap-3 self-start rounded-full border border-white/8 bg-white/[0.03] px-4 py-2 text-sm text-[var(--phile-ink)] transition hover:border-[rgba(211,176,106,0.28)] hover:bg-white/[0.05]"
        aria-label={brand}
      >
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[rgba(211,176,106,0.35)] opacity-70"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[rgba(211,176,106,0.9)]"></span>
        </span>
        <span class="font-medium tracking-[0.2em] uppercase">{brand}</span>
      </a>

      <div class="hidden items-center gap-3 md:flex">
        <p class="rounded-full border border-white/8 bg-black/10 px-4 py-2 text-[0.68rem] tracking-[0.26em] uppercase text-[var(--phile-muted)]">
          Living encyclopedia of passions
        </p>
      </div>

      <a
        href="https://x.com/np9royal"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-white/8 bg-white/[0.04] px-4 py-2 text-xs font-medium tracking-[0.22em] uppercase text-[var(--phile-ink)] transition hover:border-[rgba(211,176,106,0.32)] hover:bg-white/[0.07]"
      >
        Follow Me
      </a>
    </div>
  </div>
</header>
