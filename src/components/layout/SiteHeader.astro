---
const brand = 'Philepedia';
---

<header class="relative z-10">
  <div class="mx-auto w-full max-w-7xl px-4 pt-3 sm:px-8 sm:pt-5 lg:px-10 lg:pt-6">
    <div class="flex items-center justify-between gap-3 rounded-[1.2rem] border border-white/8 bg-white/[0.025] px-3 py-2.5 shadow-[0_14px_40px_rgba(0,0,0,0.14)] backdrop-blur-2xl sm:rounded-full sm:px-5 sm:py-3.5 md:gap-4">
      <div class="flex min-w-0 items-center gap-3">
        <a
          href="/"
          class="group inline-flex items-center gap-2.5 rounded-full border border-white/8 bg-white/[0.03] px-3.5 py-1.5 text-[0.68rem] text-[var(--phile-ink)] transition hover:border-[rgba(211,176,106,0.28)] hover:bg-white/[0.05] sm:gap-3 sm:px-4 sm:py-2 sm:text-sm"
          aria-label={brand}
        >
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[rgba(211,176,106,0.35)] opacity-70"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[rgba(211,176,106,0.9)]"></span>
          </span>
          <span class="font-medium tracking-[0.18em] uppercase sm:tracking-[0.2em]">{brand}</span>
        </a>

        <p class="hidden rounded-full border border-white/8 bg-black/10 px-4 py-2 text-[0.68rem] tracking-[0.26em] uppercase text-[var(--phile-muted)] md:inline-flex">
          Living encyclopedia of passions
        </p>
      </div>

      <a
        href="https://x.com/np9royal"
        target="_blank"
        rel="noreferrer"
        class="inline-flex shrink-0 items-center justify-center rounded-full border border-white/8 bg-white/[0.04] px-3.5 py-1.5 text-[0.62rem] font-medium tracking-[0.18em] uppercase text-[var(--phile-ink)] transition hover:border-[rgba(211,176,106,0.32)] hover:bg-white/[0.07] sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.22em]"
      >
        Follow Me
      </a>
    </div>
  </div>
</header>
