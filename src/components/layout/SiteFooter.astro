---
const year = new Date().getFullYear();
---

<footer class="relative z-10 mt-12 border-t border-white/10 bg-[linear-gradient(180deg,transparent,rgba(255,255,255,0.02))] sm:mt-16">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-6 text-sm text-[var(--phile-muted)] sm:px-8 sm:py-8 lg:flex-row lg:items-center lg:justify-between lg:px-10">
    <p class="max-w-xl text-[0.92rem] leading-6 sm:max-w-2xl sm:text-sm">
      <span class="text-[var(--phile-ink)]">Philepedia</span> is a crafted archive of passions, mood, and meaning.
    </p>

    <div class="flex flex-col items-start gap-2.5 text-left sm:flex-row sm:flex-wrap sm:items-center sm:justify-end sm:gap-4 lg:max-w-[58%]">
      <p class="text-white/58">Copyright {year}. All rights reserved.</p>
      <p class="text-[var(--phile-ink)]">Made with ❤️ by Naveen Purimittla</p>
      <a
        href="https://x.com/np9royal"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-2 text-[0.62rem] font-medium tracking-[0.18em] uppercase text-[var(--phile-ink)] backdrop-blur-xl transition hover:border-[rgba(211,176,106,0.3)] hover:bg-white/[0.06] sm:px-4 sm:text-xs sm:tracking-[0.2em]"
      >
        Follow Me
      </a>
    </div>
  </div>
</footer>
