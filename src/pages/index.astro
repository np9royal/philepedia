---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/instrument-sans";

import BaseLayout from "../layouts/BaseLayout.astro";
import ParticleField from "../components/home/ParticleField.astro";
import ReverseSearch from "../components/home/ReverseSearch";
import { homePhiles } from "../components/home/phileSeeds";
import { buildWebSiteJsonLd, serializeJsonLd } from "../lib/philes/seo";

const initialQuery = Astro.url.searchParams.get("q") ?? "";
const featured = homePhiles.slice(0, 3);
const canonical = Astro.site ? new URL("/", Astro.site).toString() : Astro.url.href;
const ogImage = Astro.site ? new URL("/og/site.png", Astro.site).toString() : undefined;
const siteJsonLd = buildWebSiteJsonLd(Astro.site);
---

<BaseLayout
	title="Philepedia - What do you love?"
	description="Philepedia is the immersive encyclopedia of -phile words, where users search what they love and discover who they are."
	canonical={canonical}
	ogImage={ogImage}
	themeColor="#07080d"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={serializeJsonLd(siteJsonLd)} />
	</Fragment>
	<section class="relative isolate overflow-hidden rounded-[2.4rem] border border-white/10 bg-[linear-gradient(180deg,rgba(16,17,26,0.92),rgba(9,10,15,0.97))] px-6 py-8 shadow-[0_30px_100px_rgba(0,0,0,0.38)] sm:px-8 sm:py-9 lg:px-10 lg:py-10">
		<ParticleField />

		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_20%,rgba(125,155,255,0.1),transparent_26%),radial-gradient(circle_at_20%_80%,rgba(255,202,150,0.08),transparent_24%),radial-gradient(circle_at_80%_75%,rgba(92,213,193,0.08),transparent_24%)]"></div>

		<div class="relative grid gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-14">
			<div class="relative max-w-2xl">
				<p class="text-[0.7rem] uppercase tracking-[0.46em] text-white/42">What do you love?</p>
				<h1 class="mt-5 max-w-xl font-[family-name:var(--font-display)] text-5xl leading-[0.92] text-white sm:text-6xl lg:text-7xl">
					Search the feeling, then find the phile.
				</h1>
				<p class="mt-6 max-w-xl text-base leading-8 text-white/68 sm:text-lg">
					Philepedia turns affection into discovery. Type what you love, watch the right word rise to the surface,
					and move into a page that feels like the passion itself.
				</p>

				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href="/explore"
						class="inline-flex items-center gap-2 rounded-full border border-white/14 bg-white/8 px-5 py-3 text-sm uppercase tracking-[0.28em] text-white transition hover:border-white/26 hover:bg-white/12"
					>
						Explore the atlas
						<span aria-hidden="true">↗</span>
					</a>
					<a
						href="#search"
						class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/20 px-5 py-3 text-sm uppercase tracking-[0.28em] text-white/78 transition hover:border-white/22 hover:bg-black/35"
					>
						Reverse search
					</a>
				</div>

				<div class="mt-10 grid gap-3 sm:grid-cols-3">
					<div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
						<p class="text-[0.64rem] uppercase tracking-[0.34em] text-white/42">Launch set</p>
						<p class="mt-3 font-[family-name:var(--font-display)] text-3xl text-white">30</p>
						<p class="mt-1 text-sm leading-6 text-white/58">flagship philes selected for depth.</p>
					</div>
					<div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
						<p class="text-[0.64rem] uppercase tracking-[0.34em] text-white/42">Motion</p>
						<p class="mt-3 font-[family-name:var(--font-display)] text-3xl text-white">Thematic</p>
						<p class="mt-1 text-sm leading-6 text-white/58">every animation has meaning.</p>
					</div>
					<div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
						<p class="text-[0.64rem] uppercase tracking-[0.34em] text-white/42">Result</p>
						<p class="mt-3 font-[family-name:var(--font-display)] text-3xl text-white">Instant</p>
						<p class="mt-1 text-sm leading-6 text-white/58">live search with a premium reveal.</p>
					</div>
				</div>

				<div class="mt-10 rounded-[1.7rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02))] p-5">
					<p class="text-[0.64rem] uppercase tracking-[0.36em] text-white/44">Featured philes</p>
					<div class="mt-4 flex flex-wrap gap-3">
						{featured.map((phile) => (
							<a
								href={`/${phile.slug}`}
								class="rounded-full border border-white/10 bg-black/20 px-4 py-2 text-sm text-white/72 transition hover:border-white/24 hover:bg-white/8 hover:text-white"
							>
								{phile.name}
							</a>
						))}
					</div>
				</div>
			</div>

			<div id="search" class="relative">
				<ReverseSearch client:load initialQuery={initialQuery} />
			</div>
		</div>
	</section>
</BaseLayout>
