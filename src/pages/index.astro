---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/instrument-sans";

import BaseLayout from "../layouts/BaseLayout.astro";
import ParticleField from "../components/home/ParticleField.astro";
import ReverseSearch from "../components/home/ReverseSearch";
import { homePhiles } from "../components/home/phileSeeds";
import { getRenderablePhiles } from "../lib/philes/content";
import { buildWebSiteJsonLd, serializeJsonLd } from "../lib/philes/seo";

const initialQuery = Astro.url.searchParams.get("q") ?? "";
const publishedPhiles = await getRenderablePhiles();
const publishedPhileCount = publishedPhiles.length;
const featured = homePhiles.slice(0, 3);
const homeMetrics = [
	{
		label: "Collection",
		value: String(publishedPhileCount),
		detail: "published philes",
	},
	{
		label: "Mode",
		value: "Editorial",
		detail: "structured for calm discovery",
	},
	{
		label: "Focus",
		value: "Instant",
		detail: "search without friction",
	},
];
const canonical = Astro.site ? new URL("/", Astro.site).toString() : Astro.url.href;
const ogImage = Astro.site ? new URL("/og/site.png", Astro.site).toString() : undefined;
const siteJsonLd = buildWebSiteJsonLd(Astro.site);
---

<BaseLayout
	title="Philepedia - What do you love?"
	description="Philepedia is the immersive encyclopedia of -phile words, where users search what they love and discover who they are."
	canonical={canonical}
	ogImage={ogImage}
	themeColor="#07080d"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={serializeJsonLd(siteJsonLd)} />
	</Fragment>
	<section class="relative isolate overflow-hidden rounded-[1.9rem] border border-white/10 bg-[linear-gradient(180deg,rgba(16,17,26,0.94),rgba(9,10,15,0.98))] px-4 py-5 shadow-[0_30px_100px_rgba(0,0,0,0.38)] sm:rounded-[2.4rem] sm:px-8 sm:py-10 lg:px-10 lg:py-12">
		<ParticleField />
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(125,155,255,0.09),transparent_30%),radial-gradient(circle_at_80%_20%,rgba(255,202,150,0.07),transparent_24%),radial-gradient(circle_at_50%_82%,rgba(92,213,193,0.06),transparent_26%)]"></div>
		<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.03),transparent_18%,transparent_82%,rgba(255,255,255,0.02))]"></div>

		<div class="relative grid gap-5 sm:gap-8 lg:grid-cols-[minmax(0,1.12fr)_minmax(28rem,0.88fr)] lg:items-start lg:gap-10">
			<div class="relative max-w-2xl pt-0.5 sm:pt-2 lg:pt-3">
				<p class="text-[0.68rem] uppercase tracking-[0.52em] text-white/38">What do you love?</p>
				<h1 class="mt-3 max-w-xl font-[family-name:var(--font-display)] text-[2.65rem] leading-[0.92] text-white sm:mt-4 sm:text-6xl lg:text-[4.7rem] xl:text-[5.2rem]">
					Search the feeling, then find the phile.
				</h1>
				<p class="mt-4 max-w-xl text-[0.96rem] leading-6 text-white/68 sm:mt-5 sm:text-lg sm:leading-8">
					Philepedia turns affection into discovery. Type what you love, watch the right word rise to the surface,
					and move into a page that feels like the passion itself.
				</p>

				<div class="mt-7 hidden flex-wrap gap-3 sm:flex">
					<a
						href="/explore"
						class="inline-flex items-center gap-2 rounded-full border border-white/14 bg-white/8 px-5 py-3 text-sm uppercase tracking-[0.28em] text-white transition hover:border-white/26 hover:bg-white/12"
					>
						Explore the atlas
						<span aria-hidden="true">↗</span>
					</a>
					<a
						href="#search"
						class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/20 px-5 py-3 text-sm uppercase tracking-[0.28em] text-white/78 transition hover:border-white/22 hover:bg-black/35"
					>
						Reverse search
					</a>
				</div>
			</div>

			<div id="search" class="relative lg:pt-1">
				<ReverseSearch client:load initialQuery={initialQuery} />
			</div>

			<div class="flex flex-col gap-4 sm:gap-6 lg:max-w-2xl">
				<div class="sm:hidden">
					<div class="flex gap-3 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
						{homeMetrics.map((metric) => (
							<div class="min-w-[9.8rem] rounded-[1.3rem] border border-white/10 bg-white/[0.05] p-3.5 shadow-[0_16px_40px_rgba(0,0,0,0.18)]">
								<p class="text-[0.58rem] uppercase tracking-[0.3em] text-white/42">{metric.label}</p>
								<p class="mt-2 font-[family-name:var(--font-display)] text-[1.75rem] leading-none text-white">
									{metric.value}
								</p>
								<p class="mt-1 text-[0.78rem] leading-5 text-white/58">{metric.detail}</p>
							</div>
						))}
					</div>
				</div>

				<div class="hidden rounded-[1.65rem] border border-white/10 bg-white/[0.05] p-4 sm:block sm:p-5">
					<div class="grid gap-4 sm:grid-cols-3 sm:divide-x sm:divide-white/10">
						{homeMetrics.map((metric, index) => (
							<div class:list={[
								index === 0 && "sm:pr-4",
								index === 1 && "sm:px-4",
								index === 2 && "sm:pl-4",
							]}>
								<p class="text-[0.64rem] uppercase tracking-[0.32em] text-white/42">{metric.label}</p>
								<p class="mt-2 font-[family-name:var(--font-display)] text-3xl text-white">{metric.value}</p>
								<p class="mt-1 text-sm leading-6 text-white/58">{metric.detail}</p>
							</div>
						))}
					</div>
				</div>

				<div class="rounded-[1.45rem] border border-white/10 bg-black/14 p-3.5 sm:rounded-[1.65rem] sm:p-5">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<p class="text-[0.64rem] uppercase tracking-[0.34em] text-white/44">Featured philes</p>
						<p class="text-[0.68rem] uppercase tracking-[0.24em] text-white/36 sm:text-xs sm:tracking-[0.28em]">
							First impressions
						</p>
					</div>
					<div class="mt-3 flex flex-wrap gap-2">
						{featured.map((phile) => (
							<a
								href={`/${phile.slug}`}
								class="rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-2 text-[0.78rem] text-white/74 transition hover:border-white/24 hover:bg-white/10 hover:text-white sm:px-4 sm:text-sm"
							>
								{phile.name}
							</a>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
