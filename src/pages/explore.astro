---
import ExploreBrowser from '../components/explore/ExploreBrowser';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../lib/search';
import { getRenderablePhiles } from '../lib/philes/content';
import { buildWebSiteJsonLd, serializeJsonLd } from '../lib/philes/seo';
import { toSearchPhiles } from '../lib/philes/search';

const title = 'Explore Philes | Philepedia';
const description =
  'Browse the editorial museum of philes, filter by mood or category, and discover the word that names what you love.';

const initialQuery = Astro.url.searchParams.get('q') ?? '';
const initialCategory = (Astro.url.searchParams.get('category') as (typeof categories)[number] | 'all') ?? 'all';
const initialMood = Astro.url.searchParams.get('mood') ?? 'all';
const initialSort = Astro.url.searchParams.get('sort') === 'az' ? 'az' : 'relevance';
const philes = toSearchPhiles(await getRenderablePhiles());
const canonical = Astro.site ? new URL('/explore', Astro.site).toString() : Astro.url.href;
const ogImage = Astro.site ? new URL('/og/site.png', Astro.site).toString() : undefined;
const siteJsonLd = buildWebSiteJsonLd(Astro.site);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  themeColor="#050816"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={serializeJsonLd(siteJsonLd)} />
  </Fragment>
  <section class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.015))] px-6 py-12 shadow-[0_30px_100px_rgba(0,0,0,0.28)] sm:px-8 lg:px-10 lg:py-14">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 top-0 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-fuchsia-500/10 blur-3xl" />
      <div class="absolute right-[-6rem] top-12 h-64 w-64 rounded-full bg-cyan-400/10 blur-3xl" />
      <div class="absolute bottom-[-8rem] left-[-6rem] h-72 w-72 rounded-full bg-amber-300/10 blur-3xl" />
    </div>

    <div class="relative max-w-3xl">
      <p class="phile-eyebrow">Philepedia Explore</p>
      <h1 class="phile-display mt-4 text-5xl leading-[0.95] text-balance sm:text-6xl lg:text-7xl">
        Search what you love. Find the word that names it.
      </h1>
      <p class="phile-prose mt-5 max-w-2xl text-base sm:text-lg">
        The first release centers a premium, editorial search experience: type a feeling, a habit,
        a place, or a fascination, then browse the philes that match it.
      </p>
    </div>

    <div class="relative mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4">
        <p class="text-xs uppercase tracking-[0.28em] text-white/40">Launch set</p>
        <p class="mt-2 text-2xl font-semibold text-white">30 curated philes</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4">
        <p class="text-xs uppercase tracking-[0.28em] text-white/40">Discovery</p>
        <p class="mt-2 text-2xl font-semibold text-white">FlexSearch-powered</p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4">
        <p class="text-xs uppercase tracking-[0.28em] text-white/40">UX</p>
        <p class="mt-2 text-2xl font-semibold text-white">Category, mood, A-Z</p>
      </div>
    </div>
  </section>

  <ExploreBrowser
    client:load
    philes={philes}
    initialQuery={initialQuery}
    initialCategory={initialCategory}
    initialMood={initialMood}
    initialSort={initialSort}
  />
</BaseLayout>
